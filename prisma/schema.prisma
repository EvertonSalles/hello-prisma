generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String  @id @default(uuid())
  name  String
  email String @unique
  age   Int
  password String
  books Book[]
}

model Book{
  id String @id @default(uuid())
  title String
  author String
  userId String
  user User @relation(fields: [userId], references: [id])
}

