generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String  @id @default(uuid())
  name  String
  email String
  age   Int
  password String
  animes Anime[]
}

model Anime {
  id String @id @default(uuid())
  title String
  genre String
  userId String
  user User @relation(fields: [userId], references: [id])
}

